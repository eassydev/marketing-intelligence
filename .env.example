# ── Core (required to boot) ───────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=5100
LOG_LEVEL=info

# Postgres (Supabase now → E2E later). Use the DIRECT/SESSION endpoint (5432),
# NOT the transaction pooler (6543) — the long-lived pool needs session features.
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Redis for BullMQ
REDIS_URL=redis://localhost:6379

# Service-to-service bearer tokens (generate long random strings)
INTERNAL_INGEST_TOKEN=change-me-ingest
MIL_SERVING_TOKEN=change-me-serving

# ── Behaviour flags ───────────────────────────────────────────────────────
MIL_DEFAULT_APP=services
MIL_ACTION_MODE=dry_run
MIL_ENABLED_APPS=services
MIL_CLICK_LOOKBACK_DAYS=7

# ── LLM seam (optional now; required when the AI brain ships) ──────────────
ANTHROPIC_API_KEY=

# ── Meta Marketing API (Phase 1) ──────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v21.0

# ── Google Ads API (Phase 1) ──────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v18

# ── In-house WhatsApp notifier (Phase 5; Meta Cloud API direct) ───────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_RECIPIENT_ALLOWLIST=
