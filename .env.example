# ── Core (required to boot) ───────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=5100
LOG_LEVEL=info

# Postgres (Supabase now → E2E later). Use the DIRECT/SESSION endpoint (5432),
# NOT the transaction pooler (6543) — the long-lived pool needs session features.
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Redis for BullMQ
REDIS_URL=redis://localhost:6379

# Service-to-service bearer tokens (generate long random strings)
INTERNAL_INGEST_TOKEN=change-me-ingest
MIL_SERVING_TOKEN=change-me-serving

# ── Behaviour flags ───────────────────────────────────────────────────────
MIL_DEFAULT_APP=services
MIL_ACTION_MODE=dry_run
MIL_ENABLED_APPS=services
MIL_CLICK_LOOKBACK_DAYS=7

# ── LLM seam (optional now; required when the AI brain ships) ──────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── GEO/AI-presence monitor (Module A) ─────────────────────────────────────
# Engine API keys are all optional: an engine without a key is skipped.
# Claude reuses ANTHROPIC_API_KEY above.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
# Brand aliases the mention detector matches (csv, case-insensitive).
MIL_BRAND_ALIASES=eassylife,eassy life,eassy.life
# Question matrix (csv) and the hard cost cap per run per engine.
MIL_GEO_CITIES=bangalore,mumbai,delhi,pune,hyderabad
MIL_GEO_CATEGORIES=home cleaning,plumbing,electrician,appliance repair,pest control
MIL_GEO_MAX_QUESTIONS=40

# ── Meta Marketing API (Phase 1) ──────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_VERSION=v21.0

# ── Meta Conversions API (Phase F) ─────────────────────────────────────────
# Server-side Purchase upload. Dark by default — flip META_CAPI_ENABLED=true
# only once META_ACCESS_TOKEN is confirmed to have dataset /events (CAPI) write
# permission. Reuses META_ACCESS_TOKEN + META_GRAPH_VERSION above.
META_CAPI_ENABLED=false
META_CAPI_DATASET_ID=1717873222070120
META_CAPI_TEST_EVENT_CODE=

# ── Google Ads API (Phase 1) ──────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v18

# ── In-house WhatsApp notifier (Phase 5; Meta Cloud API direct) ───────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_RECIPIENT_ALLOWLIST=
