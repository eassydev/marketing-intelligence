# .env.instance.example — the per-clone knobs.
# Copy the relevant lines into a new instance's .env.production (or .env) and
# change every value. See NEW_INSTANCE.md for the full clone runbook.

# ── Per-instance identity (change ALL when cloning) ─────────────────────────
MIL_INSTANCE_NAME=mil            # docker container/image/volume name (compose.prod)
MIL_QUEUE_PREFIX=mil             # BullMQ queue namespace — MUST be unique if instances share one Redis
MIL_APP_LIST=services,society    # the tenant "apps" this instance serves (csv)
MIL_DEFAULT_APP=services         # must be in MIL_APP_LIST (defaults to the first entry)
MIL_ENABLED_APPS=services        # subset of MIL_APP_LIST to run jobs for (defaults to [first])

# ── Localization ────────────────────────────────────────────────────────────
MIL_CURRENCY=INR                 # currency asserted at ingest + shown in the serving envelope
MIL_CRON_TIMEZONE=Asia/Kolkata   # timezone for every BullMQ scheduler
MIL_MARKET_DESCRIPTION=Indian home-services marketplace   # interpolated into the insights LLM prompt
MIL_BRAND_ALIASES=eassylife,eassy life,eassy.life         # brand-mention detector aliases (csv)

# ── Secrets / infra (always per-instance) ───────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
REDIS_URL=redis://localhost:6379
INTERNAL_INGEST_TOKEN=change-me-ingest-min-16-chars
MIL_SERVING_TOKEN=change-me-serving-min-16-chars
MIL_BIND_IP=127.0.0.1            # compose.prod binds the app port to this (VM private VPC IP in prod)
