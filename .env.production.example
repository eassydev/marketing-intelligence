# Copy to .env.production on the E2E VM and fill in. NEVER commit the real file.
NODE_ENV=production
HOST=0.0.0.0
PORT=5100
LOG_LEVEL=info

# Bind the published port to the VM's PRIVATE VPC IP so only the backend box can
# reach it (internal-only). Find it with `ip -4 addr`. Leave as 127.0.0.1 to keep
# it host-local until you wire the backend.
MIL_BIND_IP=10.0.0.X

# Supabase Postgres — DIRECT/SESSION endpoint (port 5432), NOT the 6543 pooler.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Redis is provided by the compose `redis` service; compose overrides this value.
REDIS_URL=redis://redis:6379

# Service-to-service bearer tokens — generate with `openssl rand -hex 24`.
INTERNAL_INGEST_TOKEN=
MIL_SERVING_TOKEN=

# Behaviour flags (keep dry_run + services-only for the foundation).
MIL_DEFAULT_APP=services
MIL_ACTION_MODE=dry_run
MIL_ENABLED_APPS=services
MIL_CLICK_LOOKBACK_DAYS=7

# Optional now; required when their slice ships.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# GEO/AI-presence monitor (Module A). All engine keys optional — an engine
# without a key is skipped; with zero keys the weekly job no-ops with a log.
# Claude reuses ANTHROPIC_API_KEY above.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
MIL_BRAND_ALIASES=eassylife,eassy life,eassy.life
MIL_GEO_CITIES=bangalore,mumbai,delhi,pune,hyderabad
MIL_GEO_CATEGORIES=home cleaning,plumbing,electrician,appliance repair,pest control
MIL_GEO_MAX_QUESTIONS=40
